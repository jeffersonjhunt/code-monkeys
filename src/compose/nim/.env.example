# Copy to .env (gitignored) and fill in.
# Used by docker compose for ${VAR} substitution AND injected into the container.

# Required — pull NIM images from nvcr.io and authenticate against NGC services.
NGC_API_KEY=nvapi-replace-me

# HuggingFace token — needed for NIM to download weights when NIM_MODEL_PATH=hf://...
HF_TOKEN=hf_replace_me

# Defaults match compose.yml; uncomment to override
# NIM_MODEL_PATH=hf://RedHatAI/Qwen3-Coder-Next-NVFP4
# NIM_SERVED_MODEL_NAME=qwen3-coder-next
