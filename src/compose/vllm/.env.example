# Copy to .env (gitignored) and fill in / override.
# Used by docker compose for ${VAR} substitution AND as the container's env file.

# Required — vLLM (via huggingface_hub) uses this to download the model.
# HF_TOKEN is the modern name; HUGGING_FACE_HUB_TOKEN is the legacy name.
# Setting either works; HF_TOKEN is preferred.
HF_TOKEN=hf_replace_me

# --- Model selection ---
# Currently serving QuantTrio/Qwen3.6-35B-A3B-AWQ (community AWQ of Qwen3.6-35B-A3B
# DeltaNet+MoE hybrid). AWQ auto-selects vLLM's awq_marlin kernel, sidestepping the
# FlashInfer NVFP4 fused-MoE path that's broken on sm_120. Long-term target is
# RedHatAI/Qwen3-Coder-Next-NVFP4 — see docs/parking-lot.md.
HF_MODEL_ID=QuantTrio/Qwen3.6-35B-A3B-AWQ
VLLM_SERVED_NAME=qwen3.6-35b-a3b-awq

# --- Tool / reasoning parsers (must match the model family) ---
#   qwen3_coder   → Qwen3-Coder / Qwen3.6 (auto tool_choice reliable)
#   hermes        → Qwen2.5 family (auto tool_choice unreliable; see runbook)
VLLM_TOOL_PARSER=qwen3_coder
VLLM_REASONING_PARSER=qwen3

# --- Spark / Blackwell kernel-path env vars ---
# Per the QuantTrio model card: dodge known-broken kernel paths on bleeding-edge HW.
VLLM_USE_DEEP_GEMM=0
VLLM_USE_FLASHINFER_MOE_FP16=1
VLLM_USE_FLASHINFER_SAMPLER=0

# --- Memory / scheduling ---
# Spark is UMA — NIM auto-clamps 0.9 → 0.5; we mirror that here for stability.
VLLM_GPU_MEM_UTIL=0.50

# Defaults match compose.yml; uncomment to override
# VLLM_IMAGE=vllm/vllm-openai:v0.20.1-cu129-ubuntu2404
# VLLM_PORT=8000
# MODEL_DIR=/srv/models
# VLLM_TP_SIZE=1
# VLLM_MAX_MODEL_LEN=32768
# VLLM_MAX_NUM_SEQS=32
