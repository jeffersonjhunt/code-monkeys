# Copy to .env (gitignored) and fill in / override.
# Used by docker compose for ${VAR} substitution AND as the container's env file.

# Required — used by `model-pull.sh` to fetch weights via huggingface_hub.
# HF_TOKEN is the modern name; HUGGING_FACE_HUB_TOKEN is the legacy name.
HF_TOKEN=hf_replace_me

# --- Model selection ---
# Weights are pre-staged on each host at ${MODEL_DIR}/${HF_MODEL_ID}/ via
# `src/scripts/model-pull.sh <repo>` (org/name HF convention). vLLM is
# launched with --model /models/${HF_MODEL_ID} — no auto-download. Current
# production model is RedHatAI/Qwen3-Coder-Next-NVFP4 (80B-A3B MoE w/
# native sm_121 NVFP4 cutlass via vllm-spark).
HF_MODEL_ID=RedHatAI/Qwen3-Coder-Next-NVFP4
VLLM_SERVED_NAME=qwen3-coder-next

# --- Tool / reasoning parsers (must match the model family) ---
#   qwen3_coder   → Qwen3-Coder / Qwen3.6 (auto tool_choice reliable)
#   hermes        → Qwen2.5 family (auto tool_choice unreliable; see runbook)
VLLM_TOOL_PARSER=qwen3_coder
VLLM_REASONING_PARSER=qwen3

# --- Spark / Blackwell kernel-path env vars ---
# Carried over from the AWQ canary; some may be no-ops under vllm-spark
# (sm_121-native cutlass) but harmless to leave in.
VLLM_USE_DEEP_GEMM=0
VLLM_USE_FLASHINFER_MOE_FP16=1
VLLM_USE_FLASHINFER_SAMPLER=0

# --- Memory / scheduling ---
# 0.75 util on 128 GB UMA leaves ~96 GB for the engine → ~42 GiB KV cache
# after NVFP4 weights, ~14x concurrency at 128K context per replica.
VLLM_GPU_MEM_UTIL=0.75
VLLM_MAX_MODEL_LEN=131072

# Defaults match compose.yml; uncomment to override.
# VLLM_IMAGE default is vllm-spark:latest (locally-built, sm_121 native
# cutlass — unblocks NVFP4 MoE and FP8 dense paths). Set to upstream below
# to fall back on hosts that don't have the local image loaded.
# VLLM_IMAGE=vllm/vllm-openai:v0.20.1-cu129-ubuntu2404
# VLLM_PORT=8000
# MODEL_DIR=/home/jhunt/Models
# VLLM_TP_SIZE=1
# VLLM_MAX_NUM_SEQS=32
