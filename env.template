# env.template — placeholder for the 'env' file managed by vault
#
# Copy this file to 'env', fill in real values, then run: ./vault lock
# The primate() function loads 'env' via --env-file at container launch.
# On the host, use: source env  (or the setenv shell function)

# --- Vault sync (S3 backup) ---
VAULT_BUCKET=my-vault-bucket
VAULT_PROFILE=default

# --- Hugging Face ---
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# --- LDAP MCP server ---
LDAP_URI=ldap://localhost:389
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=changeme
LDAP_BASE_DN=dc=example,dc=com
LDAP_USE_SSL=false

# --- Obsidian REST API MCP server ---
OBSIDIAN_API_KEY=your-obsidian-local-rest-api-key
OBSIDIAN_HOST=127.0.0.1
OBSIDIAN_PORT=27124

# --- Obsidian Tasks MCP server ---
# Path to the Obsidian vault directory (for direct markdown parsing)
OBSIDIAN_VAULT_PATH=/home/codemonkey/Documents/Obsidian

# --- Spark cluster / benchmarks ---
OPENAI_API_BASE=http://starsky:8080/v1
OPENAI_API_KEY=EMPTY
SPARK_BENCH_MODEL=qwen3-coder-next
