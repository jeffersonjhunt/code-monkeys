#!/usr/bin/env bash
#
# vault — encrypt/decrypt secrets at rest
#
# Usage: vault lock | unlock | rekey | status | sync [push|pull]
#
# Manages: ssh/ (directory), env (file), aws/ (directory)
# Encrypted to: .ssh.vault, .env.vault, and .aws.vault
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Each entry: "source:vault_file:type" (type is dir or file)
VAULTS=(
  "ssh:.ssh.vault:dir"
  "env:.env.vault:file"
  "aws:.aws.vault:dir"
)

OPENSSL_ARGS=(-aes-256-cbc -salt -pbkdf2 -iter 600000)

md5_file() {
  if command -v md5sum >/dev/null 2>&1; then
    md5sum "$1" | awk '{print $1}'
  else
    md5 -q "$1"
  fi
}

# extract md5 prefix from a bucket listing for a given vault file
# usage: extract_md5 "$listing" "aws.vault"
extract_md5() {
  echo "$1" | awk -v vf="$2" '{
    for (i=1; i<=NF; i++) {
      n = length($i)
      vl = length(vf)
      if (n == 32 + 1 + vl && substr($i, 34) == vf && substr($i, 33, 1) == ".") {
        print substr($i, 1, 32)
        exit
      }
    }
  }'
}

# extract all md5-prefixed filenames from a bucket listing for a given vault file
extract_old_files() {
  echo "$1" | awk -v vf="$2" '{
    for (i=1; i<=NF; i++) {
      n = length($i)
      vl = length(vf)
      if (n == 32 + 1 + vl && substr($i, 34) == vf && substr($i, 33, 1) == ".") {
        print $i
      }
    }
  }'
}

usage() {
  cat <<EOF
Usage: vault <command>

Commands:
  unlock    Decrypt all vaults
  lock      Encrypt all vaults and remove plaintext
  rekey     Re-encrypt all vaults with a new password
  status    Show lock/unlock state of each vault
  sync      Sync vault files with S3 (push or pull, --force to overwrite)

Environment:
  VAULT_BUCKET   S3 bucket name for sync (required for sync command)
  VAULT_PROFILE  AWS CLI profile to use for sync (optional, defaults to 'default')
EOF
}

read_password() {
  local prompt="${1:-Enter vault password:}"
  local pass
  if [[ -t 0 ]]; then
    read -rs -p "$prompt " pass </dev/tty
    echo "" >/dev/tty
  else
    read -r pass
  fi
  echo "$pass"
}

do_unlock() {
  local password
  password=$(read_password "Enter vault password:")

  local failed=false
  for entry in "${VAULTS[@]}"; do
    local source="${entry%%:*}"
    local rest="${entry#*:}"
    local vault_file="${rest%%:*}"
    local type="${rest##*:}"
    local vault_path="${SCRIPT_DIR}/${vault_file}"
    local source_path="${SCRIPT_DIR}/${source}"

    if [[ "$type" == "dir" && -d "$source_path" ]] || [[ "$type" == "file" && -f "$source_path" ]]; then
      echo "  skip: ${source} already exists"
      continue
    fi

    if [[ ! -f "$vault_path" ]]; then
      echo "  skip: ${vault_file} not found"
      continue
    fi

    if ! openssl enc -d "${OPENSSL_ARGS[@]}" -pass pass:"$password" -in "$vault_path" | tar xf - -C "$SCRIPT_DIR"; then
      echo "  FAILED: ${source}"
      failed=true
      continue
    fi

    if [[ "$type" == "dir" ]]; then
      chmod 700 "$source_path"
      find "$source_path" -type f -exec chmod 600 {} +
      echo "  unlocked: ${source}/ ($(find "$source_path" -type f | wc -l | tr -d ' ') files)"
    else
      chmod 600 "$source_path"
      echo "  unlocked: ${source}"
    fi
  done

  $failed && exit 1
  return 0
}

do_lock() {
  local password
  password=$(read_password "Enter vault password:")
  local verify
  verify=$(read_password "Verify password:")

  if [[ "$password" != "$verify" ]]; then
    echo "Passwords do not match."
    exit 1
  fi

  local found=false
  for entry in "${VAULTS[@]}"; do
    local source="${entry%%:*}"
    local rest="${entry#*:}"
    local vault_file="${rest%%:*}"
    local type="${rest##*:}"
    local vault_path="${SCRIPT_DIR}/${vault_file}"
    local source_path="${SCRIPT_DIR}/${source}"

    if [[ "$type" == "dir" && ! -d "$source_path" ]] || [[ "$type" == "file" && ! -f "$source_path" ]]; then
      echo "  skip: ${source} not found"
      continue
    fi

    found=true
    tar cf - -C "$SCRIPT_DIR" "$source" | openssl enc "${OPENSSL_ARGS[@]}" -pass pass:"$password" -out "$vault_path"

    if [[ "$type" == "dir" ]]; then
      rm -rf "$source_path"
    else
      rm -f "$source_path"
    fi
    echo "  locked: ${source} → ${vault_file}"
  done

  if ! $found; then
    echo "Nothing to lock."
    exit 1
  fi
}

do_rekey() {
  local old_password
  old_password=$(read_password "Enter current password:")
  local new_password
  new_password=$(read_password "Enter new password:")
  local verify
  verify=$(read_password "Verify new password:")

  if [[ "$new_password" != "$verify" ]]; then
    echo "Passwords do not match."
    exit 1
  fi

  local tmp
  tmp=$(mktemp)
  trap 'rm -f "$tmp"' EXIT

  for entry in "${VAULTS[@]}"; do
    local source="${entry%%:*}"
    local rest="${entry#*:}"
    local vault_file="${rest%%:*}"
    local vault_path="${SCRIPT_DIR}/${vault_file}"

    if [[ ! -f "$vault_path" ]]; then
      echo "  skip: ${vault_file} not found"
      continue
    fi

    openssl enc -d "${OPENSSL_ARGS[@]}" -pass pass:"$old_password" -in "$vault_path" -out "$tmp"
    openssl enc "${OPENSSL_ARGS[@]}" -pass pass:"$new_password" -in "$tmp" -out "$vault_path"
    echo "  rekeyed: ${vault_file}"
  done
}

do_status() {
  for entry in "${VAULTS[@]}"; do
    local source="${entry%%:*}"
    local rest="${entry#*:}"
    local vault_file="${rest%%:*}"
    local type="${rest##*:}"
    local vault_path="${SCRIPT_DIR}/${vault_file}"
    local source_path="${SCRIPT_DIR}/${source}"

    local has_vault=false
    local has_source=false
    [[ -f "$vault_path" ]] && has_vault=true
    if [[ "$type" == "dir" ]]; then
      [[ -d "$source_path" ]] && has_source=true
    else
      [[ -f "$source_path" ]] && has_source=true
    fi

    local stale=""
    if $has_source && $has_vault; then
      # check if any source file is newer than the vault
      if [[ "$type" == "dir" ]]; then
        local newer
        newer=$(find "$source_path" -newer "$vault_path" -type f \
          ! -name "known_hosts" ! -name "known_hosts.old" 2>/dev/null | head -1)
        [[ -n "$newer" ]] && stale=" (STALE — source changed since last lock)"
      else
        [[ "$source_path" -nt "$vault_path" ]] && stale=" (STALE — source changed since last lock)"
      fi
      if [[ -n "$stale" ]]; then
        printf "  %-8s UNLOCKED%s\n" "${source}" "$stale"
      else
        printf "  %-8s UNLOCKED (up to date)\n" "${source}"
      fi
    elif $has_source; then
      printf "  %-8s UNLOCKED (no vault file — run 'vault lock' to create)\n" "${source}"
    elif $has_vault; then
      printf "  %-8s LOCKED\n" "${source}"
    else
      printf "  %-8s NO VAULT\n" "${source}"
    fi
  done

  # remote comparison
  if [[ -n "${VAULT_BUCKET:-}" ]]; then
    local profile_arg=()
    if [[ -n "${VAULT_PROFILE:-}" ]]; then
      profile_arg=(--profile "$VAULT_PROFILE")
    fi

    local listing
    if listing=$(aws "${profile_arg[@]}" s3 ls "s3://${VAULT_BUCKET}/" 2>/dev/null); then
      echo ""
      for i in "${!VAULT_FILES[@]}"; do
        local vf="${VAULT_FILES[$i]}"
        local s3key="${VAULT_S3KEYS[$i]}"
        local remote_md5
        remote_md5=$(extract_md5 "$listing" "$s3key")
        local vf_path="${SCRIPT_DIR}/${vf}"

        if [[ -z "$remote_md5" ]]; then
          printf "  %-16s not in bucket\n" "${vf}"
          continue
        fi

        if [[ ! -f "$vf_path" ]]; then
          printf "  %-16s remote only (%s)\n" "${vf}" "${remote_md5:0:8}…"
          continue
        fi

        local local_md5
        local_md5=$(md5_file "$vf_path")

        if [[ "$local_md5" == "$remote_md5" ]]; then
          printf "  %-16s in sync (%s)\n" "${vf}" "${local_md5:0:8}…"
        else
          printf "  %-16s OUT OF SYNC (local: %s… remote: %s…)\n" "${vf}" "${local_md5:0:8}" "${remote_md5:0:8}"
        fi
      done
    fi
  fi

  # sync status
  local sync_file="${SCRIPT_DIR}/.vault-synced"
  echo ""
  if [[ -f "$sync_file" ]]; then
    echo "  last synced: $(head -1 "$sync_file")"
  else
    echo "  last synced: never"
  fi
}

# vault file names without leading dot (for S3 key construction)
VAULT_FILES=()
VAULT_S3KEYS=()
for entry in "${VAULTS[@]}"; do
  local_rest="${entry#*:}"
  vf="${local_rest%%:*}"
  VAULT_FILES+=("$vf")
  VAULT_S3KEYS+=("${vf#.}")
done

do_sync() {
  local direction="$1"
  local force=false
  if [[ "$direction" == "--force" ]]; then
    force=true
    direction="$2"
  elif [[ "${2:-}" == "--force" ]]; then
    force=true
  fi

  if [[ -z "${VAULT_BUCKET:-}" ]]; then
    echo "Error: VAULT_BUCKET environment variable is not set."
    echo "  export VAULT_BUCKET=<your-s3-bucket-name>"
    exit 1
  fi

  local s3_prefix="s3://${VAULT_BUCKET}"
  local profile_arg=()
  if [[ -n "${VAULT_PROFILE:-}" ]]; then
    profile_arg=(--profile "$VAULT_PROFILE")
  fi

  case "$direction" in
    push)
      local listing
      listing=$(aws "${profile_arg[@]}" s3 ls "${s3_prefix}/" 2>/dev/null || true)

      # check if remote has changed since last sync
      if ! $force; then
        local sync_file="${SCRIPT_DIR}/.vault-synced"
        if [[ -f "$sync_file" ]]; then
          local changed=()
          for i in "${!VAULT_FILES[@]}"; do
            local s3key="${VAULT_S3KEYS[$i]}"
            local remote_md5
            remote_md5=$(extract_md5 "$listing" "$s3key")
            [[ -z "$remote_md5" ]] && continue
            local saved_md5
            saved_md5=$(grep "^${s3key}:" "$sync_file" 2>/dev/null | cut -d: -f2)
            if [[ -n "$saved_md5" && "$remote_md5" != "$saved_md5" ]]; then
              changed+=("${VAULT_FILES[$i]}")
            fi
          done
          if [[ ${#changed[@]} -gt 0 ]]; then
            echo "FATAL: remote vault files have changed since last sync:"
            for f in "${changed[@]}"; do
              echo "  ${f}"
            done
            echo ""
            echo "Run './vault sync pull' to get the latest, or './vault sync --force push' to overwrite."
            exit 1
          fi
        fi
      fi

      for i in "${!VAULT_FILES[@]}"; do
        local vf="${VAULT_FILES[$i]}"
        local s3key="${VAULT_S3KEYS[$i]}"
        local vf_path="${SCRIPT_DIR}/${vf}"
        if [[ ! -f "$vf_path" ]]; then
          echo "  skip: ${vf} not found"
          continue
        fi
        local md5
        md5=$(md5_file "$vf_path")
        # remove old versions
        local old_files
        old_files=$(extract_old_files "$listing" "$s3key")
        for old in $old_files; do
          aws "${profile_arg[@]}" s3 rm "${s3_prefix}/${old}" >/dev/null 2>&1
        done
        # also remove bare vault file (legacy, no md5 prefix)
        aws "${profile_arg[@]}" s3 rm "${s3_prefix}/${vf}" >/dev/null 2>&1 || true
        aws "${profile_arg[@]}" s3 cp "$vf_path" "${s3_prefix}/${md5}.${s3key}"
        echo "  pushed: ${vf} (${md5:0:8}…)"
      done
      ;;
    pull)
      local listing
      listing=$(aws "${profile_arg[@]}" s3 ls "${s3_prefix}/" 2>/dev/null || true)
      for i in "${!VAULT_FILES[@]}"; do
        local vf="${VAULT_FILES[$i]}"
        local s3key="${VAULT_S3KEYS[$i]}"
        local remote_md5
        remote_md5=$(extract_md5 "$listing" "$s3key")
        if [[ -z "$remote_md5" ]]; then
          echo "  skip: ${vf} not found in bucket"
          continue
        fi
        local vf_path="${SCRIPT_DIR}/${vf}"
        aws "${profile_arg[@]}" s3 cp "${s3_prefix}/${remote_md5}.${s3key}" "$vf_path"
        echo "  pulled: ${vf} (${remote_md5:0:8}…)"
      done
      ;;
    *)
      echo "Usage: vault sync <push|pull>"
      exit 1
      ;;
  esac

  # record sync timestamp and remote md5s
  local sync_file="${SCRIPT_DIR}/.vault-synced"
  date "+%Y-%m-%d %H:%M:%S %Z" > "$sync_file"
  local current_listing
  current_listing=$(aws "${profile_arg[@]}" s3 ls "${s3_prefix}/" 2>/dev/null || true)
  for i in "${!VAULT_FILES[@]}"; do
    local s3key="${VAULT_S3KEYS[$i]}"
    local rmd5
    rmd5=$(extract_md5 "$current_listing" "$s3key")
    [[ -n "$rmd5" ]] && echo "${s3key}:${rmd5}" >> "$sync_file"
  done
}

if [[ $# -lt 1 ]]; then
  usage
  exit 1
fi

case "$1" in
  unlock) do_unlock ;;
  lock)   do_lock ;;
  rekey)  do_rekey ;;
  status) do_status ;;
  sync)
    shift
    if [[ -z "${1:-}" ]]; then
      echo "Usage: vault sync [--force] <push|pull>"
      exit 1
    fi
    do_sync "$@"
    ;;
  *)      usage; exit 1 ;;
esac
