#!/usr/bin/env bash
#
# vault — encrypt/decrypt personal secrets with SOPS + age (hemlighet-backed)
#
# Every secret is stored 1:1 as its own encrypted file (binary mode) in the
# PRIVATE hemlighet repo under code-monkeys/personal/, mirroring the working
# tree: env, gitconfig, face, aws/{config,credentials}, ssh/<file>. Runtime
# state (ssh/known_hosts*, ssh/agent/, aws/cli|amazonq|sso caches) is never
# stored. This repo is public — no secret, encrypted or not, ever lands here.
#
# Crypto runs in the `nyckel` container (Alpine + age + sops); age/sops are
# never installed on a host or a Mac (no brew, ever). The image is pulled
# from ECR on first use.
#
# Usage: vault <command> [flags] [item ...]
#
#   unlock [--force]           decrypt from the hemlighet clone into the
#                              working tree (files 600, dirs 700); skips
#                              files that already exist unless --force
#   lock [--keep] [--force]    encrypt new/changed files into the hemlighet
#                              clone, then remove the plaintext; --keep
#                              leaves the plaintext in place; --force
#                              re-encrypts even unchanged files
#   status [--local]           per-item state + hemlighet clone state
#                              (--local skips the git fetch)
#   rekey                      run `sops updatekeys` over all stored files
#                              after editing recipients in hemlighet/.sops.yaml
#
# Items: ssh env aws face gitconfig (default: all)
#
# Syncing is plain git now: commit + push the hemlighet clone after locking.
#
# Environment:
#   VAULT_HEMLIGHET   hemlighet clone location (default: ~/hemlighet)
#
# New-machine setup:
#   git clone ssh://git-codecommit.us-east-1.amazonaws.com/v1/repos/hemlighet ~/hemlighet
#   mkdir -p ~/.config/sops/age && cd ~/.config/sops/age \
#     && age-keygen -o keys.txt && chmod 600 keys.txt          # bin/ shim
#   # add the printed public key to the code-monkeys/personal rule in
#   # hemlighet/.sops.yaml, then run './vault rekey' on a machine that can
#   # already decrypt, and push.
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
HL="${VAULT_HEMLIGHET:-$HOME/hemlighet}"
HL_SUB="code-monkeys/personal"
AGE_DIR="$HOME/.config/sops/age"
IMAGE="nyckel"
REG="521147433280.dkr.ecr.us-east-1.amazonaws.com"

# Display order matches the old vault.
ITEMS="ssh env aws face gitconfig"

_type_of() { case "$1" in ssh|aws) echo dir ;; *) echo file ;; esac; }

# Working files never stored (runtime state). Directories are excluded
# implicitly: only top-level regular files of a dir item are considered.
_excluded() {
  case "$1" in
    ssh/known_hosts|ssh/known_hosts.old|*.tmp) return 0 ;;
  esac
  return 1
}

usage() {
  awk 'NR < 2 { next } /^#/ { sub(/^# ?/, ""); print; next } { exit }' "$0"
}

# ---------------------------------------------------------------- docker ---

DOCKER_CMD=""
_docker() {
  if [[ -z "$DOCKER_CMD" ]]; then
    if docker info >/dev/null 2>&1; then
      DOCKER_CMD="docker"
    elif sudo -n docker info >/dev/null 2>&1; then
      DOCKER_CMD="sudo"
    else
      echo "Error: cannot reach a docker daemon (tried 'docker' and 'sudo -n docker')." >&2
      exit 1
    fi
  fi
  if [[ "$DOCKER_CMD" == "sudo" ]]; then
    sudo -n docker "$@"
  else
    docker "$@"
  fi
}

_ensure_image() {
  if _docker image inspect "${IMAGE}:latest" >/dev/null 2>&1; then
    return 0
  fi
  echo "vault: pulling ${IMAGE} from ECR..." >&2
  local tok
  tok="$(_docker run --rm -v "$HOME/.aws:/root/.aws:ro" amazon/aws-cli ecr get-login-password --region us-east-1)"
  if [[ -z "$tok" ]]; then
    echo "vault: empty ECR token — check ~/.aws creds (or build locally: cd primates && make nyckel.build)" >&2
    exit 1
  fi
  printf '%s' "$tok" | _docker login --username AWS --password-stdin "$REG" >/dev/null
  _docker pull -q "${REG}/codemonkeys/${IMAGE}:latest" >/dev/null
  _docker tag "${REG}/codemonkeys/${IMAGE}:latest" "${IMAGE}:latest"
  _docker logout "$REG" >/dev/null 2>&1 || true
}

# Run a command in nyckel with the hemlighet clone at /hl (rw), the repo at
# /repo (ro or rw), and this host's age identity mounted if present.
_nyckel() {
  local repo_mode="$1"; shift
  _ensure_image
  local key_mount=()
  if [[ -f "$AGE_DIR/keys.txt" ]]; then
    key_mount=(-v "$AGE_DIR:/age:ro" -e SOPS_AGE_KEY_FILE=/age/keys.txt)
  fi
  _docker run --rm -i --user "$(id -u):$(id -g)" -e HOME=/tmp \
    ${key_mount[@]+"${key_mount[@]}"} \
    -v "$HL:/hl" \
    -v "$SCRIPT_DIR:/repo:$repo_mode" \
    -w /hl \
    "${IMAGE}:latest" "$@"
}

# ---------------------------------------------------------------- checks ---

_require_hl() {
  if [[ ! -d "$HL/.git" || ! -f "$HL/.sops.yaml" ]]; then
    echo "Error: hemlighet clone not found at $HL" >&2
    echo "  git clone ssh://git-codecommit.us-east-1.amazonaws.com/v1/repos/hemlighet $HL" >&2
    exit 1
  fi
}

_require_key() {
  if [[ ! -f "$AGE_DIR/keys.txt" ]]; then
    echo "Error: no age identity at $AGE_DIR/keys.txt — see the new-machine setup in 'vault --help'." >&2
    exit 1
  fi
}

_select_items() {
  if [[ $# -eq 0 ]]; then
    echo "$ITEMS"
    return 0
  fi
  local sel="" i k ok
  for i in "$@"; do
    ok=false
    for k in $ITEMS; do
      [[ "$i" == "$k" ]] && ok=true
    done
    if ! $ok; then
      echo "Unknown item: $i (valid: $ITEMS)" >&2
      return 2
    fi
    sel="$sel $i"
  done
  echo "$sel"
}

# ------------------------------------------------------------ enumeration ---

# Stored files of an item: relative paths (without .sops), one per line.
_stored() {
  local item="$1" type p b
  type=$(_type_of "$item")
  if [[ "$type" == "file" ]]; then
    [[ -f "$HL/$HL_SUB/$item.sops" ]] && echo "$item"
    return 0
  fi
  [[ -d "$HL/$HL_SUB/$item" ]] || return 0
  find "$HL/$HL_SUB/$item" -maxdepth 1 -type f -name '*.sops' 2>/dev/null | sort | \
    while IFS= read -r p; do
      b="$(basename "$p")"
      echo "$item/${b%.sops}"
    done
}

# Lockable working files of an item: relative paths, one per line.
_working() {
  local item="$1" type p b
  type=$(_type_of "$item")
  if [[ "$type" == "file" ]]; then
    [[ -f "$SCRIPT_DIR/$item" ]] && echo "$item"
    return 0
  fi
  [[ -d "$SCRIPT_DIR/$item" ]] || return 0
  find "$SCRIPT_DIR/$item" -maxdepth 1 -type f 2>/dev/null | sort | \
    while IFS= read -r p; do
      b="$(basename "$p")"
      _excluded "$item/$b" && continue
      echo "$item/$b"
    done
}

# -------------------------------------------------------------- commands ---

do_unlock() {
  local force=false sel=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) force=true ;;
      -*) echo "Unknown flag for unlock: $1" >&2; exit 2 ;;
      *) sel+=("$1") ;;
    esac
    shift
  done
  local items
  items=$(_select_items ${sel[@]+"${sel[@]}"})
  _require_hl
  _require_key

  local to_dec=() skipped=0 item f
  for item in $items; do
    while IFS= read -r f; do
      [[ -n "$f" ]] || continue
      if [[ -f "$SCRIPT_DIR/$f" ]] && ! $force; then
        skipped=$((skipped + 1))
        continue
      fi
      to_dec+=("$f")
    done < <(_stored "$item")
  done

  if [[ ${#to_dec[@]} -eq 0 ]]; then
    if [[ $skipped -gt 0 ]]; then
      echo "  nothing to unlock ($skipped file(s) already present — use --force to overwrite)"
    else
      echo "  nothing to unlock (no stored files for: ${items# })"
    fi
    return 0
  fi

  for item in $items; do
    if [[ "$(_type_of "$item")" == "dir" && ! -d "$SCRIPT_DIR/$item" ]]; then
      mkdir -p "$SCRIPT_DIR/$item"
    fi
  done

  if ! _nyckel rw sh -c '
        set -e
        for f in "$@"; do
          sops -d --input-type binary --output-type binary \
            --output "/repo/$f.tmp" "/hl/'"$HL_SUB"'/$f.sops"
        done' sops-batch "${to_dec[@]}"; then
    for f in "${to_dec[@]}"; do rm -f "$SCRIPT_DIR/$f.tmp"; done
    echo "  FAILED: decrypt error — is this host's age key a recipient in hemlighet/.sops.yaml?" >&2
    exit 1
  fi

  for f in "${to_dec[@]}"; do
    mv -f "$SCRIPT_DIR/$f.tmp" "$SCRIPT_DIR/$f"
    chmod 600 "$SCRIPT_DIR/$f"
    # Align mtimes so status can spot local edits made after unlock.
    touch -r "$HL/$HL_SUB/$f.sops" "$SCRIPT_DIR/$f"
    echo "  unlocked: $f"
  done
  for item in $items; do
    [[ "$(_type_of "$item")" == "dir" && -d "$SCRIPT_DIR/$item" ]] && chmod 700 "$SCRIPT_DIR/$item"
  done
  [[ $skipped -gt 0 ]] && echo "  skipped $skipped existing file(s) (use --force to overwrite)"
  return 0
}

do_lock() {
  local keep=false force=false sel=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --keep)  keep=true ;;
      --force) force=true ;;
      -*) echo "Unknown flag for lock: $1" >&2; exit 2 ;;
      *) sel+=("$1") ;;
    esac
    shift
  done
  local items
  items=$(_select_items ${sel[@]+"${sel[@]}"})
  _require_hl

  local to_enc=() working=() item f sopsf unchanged=0
  for item in $items; do
    while IFS= read -r f; do
      [[ -n "$f" ]] || continue
      working+=("$f")
      sopsf="$HL/$HL_SUB/$f.sops"
      if ! $force && [[ -f "$sopsf" ]] && ! [[ "$SCRIPT_DIR/$f" -nt "$sopsf" ]]; then
        unchanged=$((unchanged + 1))
        continue
      fi
      to_enc+=("$f")
    done < <(_working "$item")
    # Stored files whose plaintext is gone: flag, never silently drop.
    while IFS= read -r f; do
      [[ -n "$f" ]] || continue
      if [[ ! -f "$SCRIPT_DIR/$f" ]]; then
        echo "  note: $f.sops is in hemlighet but $f is gone locally (git rm it there if intentional)"
      fi
    done < <(_stored "$item")
  done

  if [[ ${#working[@]} -eq 0 ]]; then
    echo "Nothing to lock."
    exit 1
  fi

  if [[ ${#to_enc[@]} -gt 0 ]]; then
    _nyckel ro sh -c '
      set -e
      for f in "$@"; do
        mkdir -p "$(dirname "/hl/'"$HL_SUB"'/$f.sops")"
        sops -e --input-type binary --output-type binary \
          --filename-override "'"$HL_SUB"'/$f" \
          --output "/hl/'"$HL_SUB"'/$f.sops" "/repo/$f"
      done' sops-batch "${to_enc[@]}"
    for f in "${to_enc[@]}"; do
      echo "  locked: $f -> $HL_SUB/$f.sops"
    done
  fi
  [[ $unchanged -gt 0 ]] && echo "  unchanged: $unchanged file(s) already current in hemlighet (--force to re-encrypt)"

  if ! $keep; then
    for f in ${working[@]+"${working[@]}"}; do
      rm -f "$SCRIPT_DIR/$f"
    done
    echo "  plaintext removed (${#working[@]} file(s)) — 'vault unlock' to restore"
  fi

  echo ""
  if [[ -n "$(git -C "$HL" status --porcelain -- "$HL_SUB" 2>/dev/null)" ]]; then
    git -C "$HL" status --short -- "$HL_SUB" | sed 's/^/  /'
    echo "  hemlighet has uncommitted changes — commit and push:"
    echo "    git -C $HL add $HL_SUB && git -C $HL commit -m 'personal: lock' && git -C $HL push"
  else
    echo "  hemlighet unchanged"
  fi
  return 0
}

do_rekey() {
  _require_hl
  _require_key
  echo "Re-wrapping data keys for recipients in $HL/.sops.yaml..."
  _nyckel ro sh -c '
    set -e
    find "/hl/'"$HL_SUB"'" -type f -name "*.sops" | sort | while IFS= read -r f; do
      sops updatekeys -y "$f" >/dev/null 2>&1 || { echo "  FAILED: ${f#/hl/}"; exit 1; }
      echo "  rekeyed: ${f#/hl/}"
    done'
  echo ""
  echo "  commit and push hemlighet to publish the new recipients."
  return 0
}

do_status() {
  local do_fetch=true sel=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --local) do_fetch=false ;;
      -*) echo "Unknown flag for status: $1" >&2; exit 2 ;;
      *) sel+=("$1") ;;
    esac
    shift
  done
  local items
  items=$(_select_items ${sel[@]+"${sel[@]}"})
  _require_hl

  local item f sopsf verdict
  local n_work n_stored n_stale n_orphan
  for item in $items; do
    n_work=0 n_stored=0 n_stale=0 n_orphan=0
    while IFS= read -r f; do
      [[ -n "$f" ]] || continue
      n_work=$((n_work + 1))
      sopsf="$HL/$HL_SUB/$f.sops"
      if [[ ! -f "$sopsf" || "$SCRIPT_DIR/$f" -nt "$sopsf" ]]; then
        n_stale=$((n_stale + 1))
      fi
    done < <(_working "$item")
    while IFS= read -r f; do
      [[ -n "$f" ]] || continue
      n_stored=$((n_stored + 1))
      [[ -f "$SCRIPT_DIR/$f" ]] || n_orphan=$((n_orphan + 1))
    done < <(_stored "$item")

    if [[ $n_work -eq 0 && $n_stored -eq 0 ]]; then
      verdict="NO VAULT"
    elif [[ $n_work -eq 0 ]]; then
      verdict="LOCKED ($n_stored file(s) in hemlighet)"
    elif [[ $n_stale -gt 0 ]]; then
      verdict="UNLOCKED (STALE — $n_stale of $n_work file(s) new/changed since last lock)"
    else
      verdict="UNLOCKED (up to date)"
    fi
    if [[ $n_orphan -gt 0 && $n_work -gt 0 ]]; then
      verdict="${verdict} [$n_orphan stored file(s) gone locally]"
    fi
    printf "  %-9s %s\n" "$item" "$verdict"
  done

  echo ""
  if [[ ! -f "$AGE_DIR/keys.txt" ]]; then
    echo "  age key: MISSING ($AGE_DIR/keys.txt) — unlock will fail; see 'vault --help'"
  fi
  local fetch_note="" head dirty upstream ahead_behind
  if $do_fetch; then
    git -C "$HL" fetch -q 2>/dev/null || fetch_note=", fetch failed (offline?)"
  else
    fetch_note=", --local (no fetch)"
  fi
  head=$(git -C "$HL" rev-parse --short HEAD 2>/dev/null || echo "?")
  dirty=$({ git -C "$HL" status --porcelain 2>/dev/null || true; } | wc -l | tr -d ' ')
  local state="clean"
  [[ "$dirty" != "0" ]] && state="$dirty uncommitted change(s)"
  upstream=$(git -C "$HL" rev-parse --abbrev-ref '@{u}' 2>/dev/null || true)
  if [[ -n "$upstream" ]]; then
    ahead_behind=$(git -C "$HL" rev-list --left-right --count "HEAD...@{u}" 2>/dev/null || echo "? ?")
    set -- $ahead_behind
    local ahead="${1:-?}" behind="${2:-?}"
    if [[ "$ahead" == "0" && "$behind" == "0" ]]; then
      state="$state, in sync with $upstream"
    else
      state="$state, ahead $ahead / behind $behind of $upstream"
    fi
  fi
  echo "  hemlighet: $HL @ $head ($state$fetch_note)"
}

# ------------------------------------------------------------------ main ---

if [[ $# -lt 1 ]]; then
  usage
  exit 1
fi

case "$1" in
  -h|--help) usage; exit 0 ;;
  unlock) shift; do_unlock "$@" ;;
  lock)   shift; do_lock "$@" ;;
  rekey)  shift; do_rekey "$@" ;;
  status) shift; do_status "$@" ;;
  sync)
    echo "vault sync is retired — hemlighet is a git repo now:" >&2
    echo "  git -C $HL pull / push" >&2
    exit 2
    ;;
  *) usage; exit 1 ;;
esac
