#!/usr/bin/env bash
#
# vault — encrypt/decrypt secrets at rest
#
# Usage: vault lock | unlock | rekey | status | sync <push|pull>
#
# Manages: ssh/ (directory), env (file), aws/ (directory), face (file), gitconfig (file)
# Encrypted to: .ssh.vault, .env.vault, .aws.vault, .face.vault, .gitconfig.vault
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Prefer the repo's bin/ shims (e.g. aws wrapper that falls back to a container).
PATH="${SCRIPT_DIR}/bin:${PATH}"

# Each entry: "source:vault_file:type" (type is dir or file)
VAULTS=(
  "ssh:.ssh.vault:dir"
  "env:.env.vault:file"
  "aws:.aws.vault:dir"
  "face:.face.vault:file"
  "gitconfig:.gitconfig.vault:file"
)

OPENSSL_ARGS=(-aes-256-cbc -salt -pbkdf2 -iter 600000)

# aws cli wrapper that adds --profile if VAULT_PROFILE is set
_aws() {
  if [[ -n "${VAULT_PROFILE:-}" ]]; then
    aws --profile "$VAULT_PROFILE" "$@"
  else
    aws "$@"
  fi
}

SYNC_INCLUDES=(--exclude "*" --include "*.vault")

usage() {
  cat <<EOF
Usage: vault <command>

Commands:
  unlock    Decrypt all vaults
  lock      Encrypt all vaults and remove plaintext
  rekey     Re-encrypt all vaults with a new password
  status    Show lock/unlock state of each vault and S3 sync state
  sync      Sync vault files with S3 (push or pull, optional --force on pull)

Environment:
  VAULT_BUCKET   S3 bucket name for sync (required for sync command)
  VAULT_PROFILE  AWS CLI profile to use for sync (optional, defaults to 'default')
EOF
}

read_password() {
  local prompt="${1:-Enter vault password:}"
  local pass
  if [[ -t 0 ]]; then
    read -rs -p "$prompt " pass </dev/tty
    echo "" >/dev/tty
  else
    read -r pass
  fi
  echo "$pass"
}

do_unlock() {
  local password
  password=$(read_password "Enter vault password:")

  local failed=false
  for entry in "${VAULTS[@]}"; do
    local source="${entry%%:*}"
    local rest="${entry#*:}"
    local vault_file="${rest%%:*}"
    local type="${rest##*:}"
    local vault_path="${SCRIPT_DIR}/${vault_file}"
    local source_path="${SCRIPT_DIR}/${source}"

    if [[ "$type" == "dir" && -d "$source_path" ]] || [[ "$type" == "file" && -f "$source_path" ]]; then
      echo "  skip: ${source} already exists"
      continue
    fi

    if [[ ! -f "$vault_path" ]]; then
      echo "  skip: ${vault_file} not found"
      continue
    fi

    if ! openssl enc -d "${OPENSSL_ARGS[@]}" -pass pass:"$password" -in "$vault_path" | tar xf - -C "$SCRIPT_DIR"; then
      echo "  FAILED: ${source}"
      failed=true
      continue
    fi

    if [[ "$type" == "dir" ]]; then
      chmod 700 "$source_path"
      find "$source_path" -type f -exec chmod 600 {} +
      echo "  unlocked: ${source}/ ($(find "$source_path" -type f | wc -l | tr -d ' ') files)"
    else
      chmod 600 "$source_path"
      echo "  unlocked: ${source}"
    fi
  done

  $failed && exit 1
  return 0
}

do_lock() {
  local password
  password=$(read_password "Enter vault password:")
  local verify
  verify=$(read_password "Verify password:")

  if [[ "$password" != "$verify" ]]; then
    echo "Passwords do not match."
    exit 1
  fi

  local found=false
  for entry in "${VAULTS[@]}"; do
    local source="${entry%%:*}"
    local rest="${entry#*:}"
    local vault_file="${rest%%:*}"
    local type="${rest##*:}"
    local vault_path="${SCRIPT_DIR}/${vault_file}"
    local source_path="${SCRIPT_DIR}/${source}"

    if [[ "$type" == "dir" && ! -d "$source_path" ]] || [[ "$type" == "file" && ! -f "$source_path" ]]; then
      echo "  skip: ${source} not found"
      continue
    fi

    found=true
    tar cf - -C "$SCRIPT_DIR" "$source" | openssl enc "${OPENSSL_ARGS[@]}" -pass pass:"$password" -out "$vault_path"

    if [[ "$type" == "dir" ]]; then
      rm -rf "$source_path"
    else
      rm -f "$source_path"
    fi
    echo "  locked: ${source} → ${vault_file}"
  done

  if ! $found; then
    echo "Nothing to lock."
    exit 1
  fi
}

do_rekey() {
  local old_password
  old_password=$(read_password "Enter current password:")
  local new_password
  new_password=$(read_password "Enter new password:")
  local verify
  verify=$(read_password "Verify new password:")

  if [[ "$new_password" != "$verify" ]]; then
    echo "Passwords do not match."
    exit 1
  fi

  local tmp
  tmp=$(mktemp)
  trap 'rm -f "$tmp"' EXIT

  for entry in "${VAULTS[@]}"; do
    local source="${entry%%:*}"
    local rest="${entry#*:}"
    local vault_file="${rest%%:*}"
    local vault_path="${SCRIPT_DIR}/${vault_file}"

    if [[ ! -f "$vault_path" ]]; then
      echo "  skip: ${vault_file} not found"
      continue
    fi

    openssl enc -d "${OPENSSL_ARGS[@]}" -pass pass:"$old_password" -in "$vault_path" -out "$tmp"
    openssl enc "${OPENSSL_ARGS[@]}" -pass pass:"$new_password" -in "$tmp" -out "$vault_path"
    echo "  rekeyed: ${vault_file}"
  done
}

do_status() {
  # Pre-fetch S3 dryrun output once if a bucket is configured. The dryrun
  # tells us per-file what `aws s3 sync` would do in each direction:
  # a "download:" line in the pull dryrun means S3 has the file and local
  # doesn't, or S3 is newer; an "upload:" line in the push dryrun means
  # local has the file and S3 doesn't, or local is newer.
  local s3_state="disabled"
  local pull_dry="" push_dry="" s3_err=""
  if [[ -n "${VAULT_BUCKET:-}" ]]; then
    local s3_uri="s3://${VAULT_BUCKET}"
    if pull_dry=$(_aws s3 sync "$s3_uri" "$SCRIPT_DIR" "${SYNC_INCLUDES[@]}" --dryrun 2>&1) \
    && push_dry=$(_aws s3 sync "$SCRIPT_DIR" "$s3_uri" "${SYNC_INCLUDES[@]}" --dryrun 2>&1); then
      s3_state="ok"
    else
      s3_state="error"
      s3_err="$pull_dry"
    fi
  fi

  for entry in "${VAULTS[@]}"; do
    local source="${entry%%:*}"
    local rest="${entry#*:}"
    local vault_file="${rest%%:*}"
    local type="${rest##*:}"
    local vault_path="${SCRIPT_DIR}/${vault_file}"
    local source_path="${SCRIPT_DIR}/${source}"

    local has_vault=false
    local has_source=false
    [[ -f "$vault_path" ]] && has_vault=true
    if [[ "$type" == "dir" ]]; then
      [[ -d "$source_path" ]] && has_source=true
    else
      [[ -f "$source_path" ]] && has_source=true
    fi

    # Local verdict.
    local local_verdict=""
    if $has_source && $has_vault; then
      local stale=""
      if [[ "$type" == "dir" ]]; then
        local newer
        newer=$(find "$source_path" -newer "$vault_path" -type f \
          ! -name "known_hosts" ! -name "known_hosts.old" 2>/dev/null | head -1)
        [[ -n "$newer" ]] && stale="STALE — source changed since last lock"
      else
        [[ "$source_path" -nt "$vault_path" ]] && stale="STALE — source changed since last lock"
      fi
      if [[ -n "$stale" ]]; then
        local_verdict="UNLOCKED ($stale)"
      else
        local_verdict="UNLOCKED (up to date)"
      fi
    elif $has_source; then
      local_verdict="UNLOCKED (no vault file — run 'vault lock' to create)"
    elif $has_vault; then
      local_verdict="LOCKED"
    else
      local_verdict="NO VAULT"
    fi

    # S3 verdict.
    local s3_verdict=""
    case "$s3_state" in
      ok)
        local would_pull would_push
        would_pull=$(echo "$pull_dry" | grep -F "$vault_file" || true)
        would_push=$(echo "$push_dry" | grep -F "$vault_file" || true)
        if [[ "$would_pull" == *"download:"* && "$would_push" == *"upload:"* ]]; then
          s3_verdict="s3 DIVERGED — manual review needed"
        elif [[ "$would_pull" == *"download:"* ]]; then
          s3_verdict="s3 NEWER — run 'vault sync pull'"
        elif [[ "$would_push" == *"upload:"* ]]; then
          s3_verdict="s3 LOCAL NEWER — run 'vault sync push'"
        else
          s3_verdict="s3 in sync"
        fi
        ;;
      error) s3_verdict="s3 unreachable" ;;
    esac

    # Combine: splice s3 verdict into existing parens, or add new parens.
    if [[ -n "$s3_verdict" ]]; then
      if [[ "$local_verdict" == *"("*")" ]]; then
        local_verdict="${local_verdict%)}, ${s3_verdict})"
      else
        local_verdict="${local_verdict} (${s3_verdict})"
      fi
    fi

    printf "  %-9s %s\n" "${source}" "$local_verdict"
  done

  # Trailer: bucket / sync errors / last-synced timestamp.
  echo ""
  if [[ "$s3_state" == "disabled" ]]; then
    echo "  S3 sync disabled (VAULT_BUCKET not set)"
    return
  fi
  if [[ "$s3_state" == "error" ]]; then
    echo "  S3 sync error (bucket: ${VAULT_BUCKET}) — check credentials/network:"
    echo "$s3_err" | sed 's/^/    /' | head -3
  fi
  local sync_file="${SCRIPT_DIR}/.vault-synced"
  if [[ -f "$sync_file" ]]; then
    echo "  last synced: $(cat "$sync_file")"
  else
    echo "  last synced: never"
  fi
}

do_sync() {
  local direction="$1"
  shift

  local force=false
  for arg in "$@"; do
    case "$arg" in
      --force) force=true ;;
      *) echo "Unknown option for sync: $arg"; exit 1 ;;
    esac
  done

  if [[ -z "${VAULT_BUCKET:-}" ]]; then
    echo "Error: VAULT_BUCKET environment variable is not set."
    echo "  export VAULT_BUCKET=<your-s3-bucket-name>"
    exit 1
  fi

  local s3_uri="s3://${VAULT_BUCKET}"

  case "$direction" in
    push)
      if $force; then
        echo "Note: --force is a no-op for push (push always uploads newer/missing files)."
      fi
      _aws s3 sync "$SCRIPT_DIR" "$s3_uri" "${SYNC_INCLUDES[@]}"
      ;;
    pull)
      if $force; then
        echo "WARNING: --force will delete local *.vault files and re-download from S3."
        echo "  Any local-only changes (locked but not yet pushed) will be lost."
        if [[ -t 0 ]]; then
          read -r -p "Continue? [y/N] " ans
          [[ "$ans" =~ ^[Yy] ]] || { echo "Aborted."; exit 1; }
        fi
        for entry in "${VAULTS[@]}"; do
          local rest="${entry#*:}"
          local vault_file="${rest%%:*}"
          rm -f "${SCRIPT_DIR}/${vault_file}"
        done
      fi
      _aws s3 sync "$s3_uri" "$SCRIPT_DIR" "${SYNC_INCLUDES[@]}"
      ;;
    *)
      echo "Usage: vault sync <push|pull> [--force]"
      exit 1
      ;;
  esac

  date "+%Y-%m-%d %H:%M:%S %Z" > "${SCRIPT_DIR}/.vault-synced"
}

if [[ $# -lt 1 ]]; then
  usage
  exit 1
fi

case "$1" in
  unlock) do_unlock ;;
  lock)   do_lock ;;
  rekey)  do_rekey ;;
  status) do_status ;;
  sync)
    if [[ -z "${2:-}" ]]; then
      echo "Usage: vault sync <push|pull> [--force]"
      exit 1
    fi
    shift
    do_sync "$@"
    ;;
  *)      usage; exit 1 ;;
esac
