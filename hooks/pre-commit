#!/usr/bin/env bash
#
# pre-commit — warn if any vault is stale
#

REPO_DIR="$(git rev-parse --show-toplevel)"

if stale=$("$REPO_DIR/vault" status 2>/dev/null | grep "STALE"); then
  echo ""
  echo "WARNING: vault may be stale:"
  echo "$stale"
  echo "  Run './vault lock' to re-encrypt before syncing."
  echo ""
fi

exit 0
