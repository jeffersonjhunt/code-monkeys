# cluster.env — inventory and SSH details for this cluster.
# Copy to cluster.env (gitignored) and edit for your hosts.
#
# All cluster scripts (deploy.sh, ship-image.sh, model-pull.sh, smoke-test.sh,
# bench.py, bench-sweep.sh, bootstrap.sh) source this file via
# src/scripts/lib/load-config.sh.

# SSH user on every host. NOPASSWD sudo + docker group expected on each box.
SSH_USER=jhunt

# Replica hosts — space-separated FQDNs (use the fully-qualified name, e.g.
# hostA.tworivers, never short names or IPs — the fleet convention, and what the
# project known_hosts trusts). SSH-reachable; order is preserved in haproxy
# backend lines and in `deploy.sh all`.
REPLICAS="hostA.example hostB.example"

# Which replica fronts the cluster with HAProxy. Must be one of REPLICAS
# (HAProxy runs alongside the vLLM replica on that box).
LB_HOST=A

# Ports. VLLM_PORT is the per-replica vLLM port; LB_PORT is the public
# HAProxy port. LB_STATS_PORT is the loopback-only HAProxy stats/health port.
VLLM_PORT=8000
LB_PORT=8080
LB_STATS_PORT=8404
