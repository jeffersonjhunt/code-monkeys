# cluster.env — inventory and SSH details for this cluster.
# Copy to cluster.env (gitignored) and edit for your hosts.
#
# All cluster scripts (deploy.sh, model-pull.sh, smoke-test.sh,
# bench.py, bench-sweep.sh, bootstrap.sh) source this file via
# src/scripts/lib/load-config.sh.

# SSH user on every host. NOPASSWD sudo + docker group expected on each box.
SSH_USER=gdeceiver

# Replica hosts — space-separated FQDNs (use the fully-qualified name, e.g.
# hostA.tworivers, never short names or IPs — the fleet convention, and what the
# project known_hosts trusts). SSH-reachable; order is preserved in haproxy
# backend lines and in `deploy.sh all`.
REPLICAS="hostA.example hostB.example"

# Which host fronts the cluster with the LiteLLM router. May be one of REPLICAS
# (co-located with a vLLM replica) or a standalone host outside REPLICAS — e.g.
# the control plane (load-config.sh warns, doesn't error, if it's not a replica).
LB_HOST=A

# Ports. VLLM_PORT is the per-replica vLLM port; LB_PORT is the public
# LiteLLM router port. LB_STATS_PORT is retained only for the fallback HAProxy stack.
VLLM_PORT=8000
LB_PORT=8080
LB_STATS_PORT=8404

# Where model weights live on each replica, in the flat <org>/<name> HF layout.
# This is ONE setting on purpose: bootstrap.sh creates it, model-pull.sh stages into it, and
# the vllm stack mounts it read-only at /models. If they disagree, vLLM serves a directory the
# weights were never downloaded to. Must match MODEL_DIR in src/compose/vllm/.env.
MODEL_DIR=/srv/models
