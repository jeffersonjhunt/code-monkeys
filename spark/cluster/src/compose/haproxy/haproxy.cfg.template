# HAProxy config template for spark-cluster.
# deploy.sh renders this to haproxy.cfg by replacing the `# __REPLICAS__`
# marker below with one `server <host> <host>:$VLLM_PORT check` line per
# entry in $REPLICAS (from cluster.env). Edit this file — never edit the
# generated haproxy.cfg, it's overwritten on every deploy.
# Backends use hostnames (resolved at HAProxy startup); DNS is the source of truth.

global
    log stdout format raw local0
    daemon
    maxconn 4096

defaults
    log global
    mode http
    option httplog
    option dontlognull
    timeout connect 5s
    timeout client 600s
    timeout server 600s
    retries 3

# Stats and self-healthcheck on loopback only
frontend lb_stats
    bind 127.0.0.1:8404
    mode http
    monitor-uri /health
    stats enable
    stats uri /stats
    stats refresh 10s

frontend vllm_in
    # Non-privileged port — haproxy:alpine runs as the `haproxy` user and
    # cannot bind <1024 on the host (network_mode: host). If you ever want
    # :80, add `cap_add: [NET_BIND_SERVICE]` in compose.yml and switch back.
    bind 0.0.0.0:8080
    default_backend vllm_pool

backend vllm_pool
    balance roundrobin
    option httpchk
    http-check send meth GET uri /health
    http-check expect status 200
    default-server inter 10s fall 3 rise 2 maxconn 1024
    # __REPLICAS__
