{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "model": "spark/qwen3-coder-next",
  "enabled_providers": ["spark"],
  "provider": {
    "spark": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Spark vLLM",
      "options": {
        "baseURL": "http://LITELLM_HOST:8888/v1",
        "apiKey": "sk-local"
      },
      "models": {
        "qwen3-coder-next": {
          "name": "Qwen3 Coder (vLLM)",
          "tool_call": true,
          "reasoning": true,
          "temperature": true,
          "attachment": false,
          "limit": {
            "context": 131072,
            "output": 32768
          }
        }
      }
    }
  },
  "mcp": {
    "corpus": {
      "type": "remote",
      "url": "http://CORPUS_MCP_HOST:8087/mcp",
      "enabled": false
    }
  }
}
