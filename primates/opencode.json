{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "model": "spark/qwen3-coder-next",
  "enabled_providers": ["spark"],
  "provider": {
    "spark": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Spark vLLM",
      "options": {
        "baseURL": "http://minerva.tworivers:8888/v1",
        "apiKey": "sk-local"
      },
      "models": {
        "qwen3-coder-next": {
          "name": "Qwen3 Coder (vLLM)",
          "tool_call": true,
          "reasoning": true,
          "temperature": true,
          "attachment": false,
          "limit": {
            "context": 131072,
            "output": 32768
          }
        },
        "reasoning": {
          "name": "Qwen3.6 Reasoning A3B (vLLM)",
          "tool_call": true,
          "reasoning": true,
          "temperature": true,
          "attachment": false,
          "limit": {
            "context": 131072,
            "output": 32768
          }
        },
        "fastpath": {
          "name": "Qwen3-30B-A3B Instruct (fast, 8k)",
          "tool_call": true,
          "reasoning": false,
          "temperature": true,
          "attachment": false,
          "limit": {
            "context": 8192,
            "output": 4096
          }
        }
      }
    }
  },
  "mcp": {
    "corpus": {
      "type": "remote",
      "url": "http://minerva.tworivers:8087/mcp",
      "enabled": true
    }
  }
}
