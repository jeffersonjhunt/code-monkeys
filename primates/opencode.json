{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "model": "starsky/qwen3-coder-next",
  "provider": {
    "starsky": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Starsky vLLM",
      "options": {
        "baseURL": "http://minerva.tworivers:8888/v1",
        "apiKey": "sk-local"
      },
      "models": {
        "qwen3-coder-next": {
          "name": "Qwen3 Coder (vLLM)",
          "tool_call": true,
          "reasoning": true,
          "temperature": true,
          "attachment": false,
          "limit": {
            "context": 131072,
            "output": 32768
          }
        }
      }
    }
  },
  "mcp": {
    "corpus": {
      "type": "remote",
      "url": "http://minerva.tworivers:8087/mcp",
      "enabled": true
    }
  }
}
