#!/usr/bin/env bash
# spark-build — build spark-class primate images on a cluster node, with drain/restore.
# See ../SKILL.md for usage and rationale.
set -euo pipefail

ALL_IMAGES=(cuda-llama-cpp cuda-comfy cuda-vllm)

usage() {
  cat <<'EOF'
Usage: spark-build [options]

Build spark-class primate images on a cluster replica, draining it from the
cluster first so users keep getting served by the remaining replicas.

Options:
  --host HOST       SSH target (default: first non-LB replica from cluster.env;
                    use FQDN like hutch.tworivers if bare name does not resolve)
  --lb-host HOST    SSH target for the LB host (default: $LB_HOST from
                    cluster.env, auto-suffixed with --host's domain when
                    --host is an FQDN and LB_HOST is bare).
  --image NAME      Image to build; repeatable. NAME may be "all" or one of:
                    cuda-llama-cpp, cuda-comfy, cuda-vllm.
                    Default: all three.
  --sync MODE       Code sync to host: "rsync" (working tree) or "git".
                    Default: rsync.
  --ref REF         Git ref for --sync git. Default: current branch.
  --dry-run         Print every step without executing (no network).
  --skip-drain      Do not stop vLLM on the host before building.
  --allow-outage    Proceed even when draining leaves the cluster with no serving
                    replica (i.e. a single-replica cluster). Without this, the
                    build refuses rather than silently taking the model offline.
  --no-restart      Do not restart vLLM on the host after building.
  --force           Allow targeting the LB host (takes the cluster API down).
  --help            Show this help.

Reads spark/cluster/cluster.env for REPLICAS, LB_HOST, SSH_USER,
VLLM_PORT and LB_PORT.
EOF
}

# ---- parse args ---------------------------------------------------------
HOST=""
LB_HOST_OVERRIDE=""
IMAGES=()
SYNC=rsync
GIT_REF=""
DRY_RUN=0
SKIP_DRAIN=0
NO_RESTART=0
FORCE=0
ALLOW_OUTAGE=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --host)        HOST="$2"; shift 2 ;;
    --lb-host)     LB_HOST_OVERRIDE="$2"; shift 2 ;;
    --image)       IMAGES+=("$2"); shift 2 ;;
    --sync)        SYNC="$2"; shift 2 ;;
    --ref)         GIT_REF="$2"; shift 2 ;;
    --dry-run)     DRY_RUN=1; shift ;;
    --skip-drain)  SKIP_DRAIN=1; shift ;;
    --allow-outage) ALLOW_OUTAGE=1; shift ;;
    --no-restart)  NO_RESTART=1; shift ;;
    --force)       FORCE=1; shift ;;
    --help|-h)     usage; exit 0 ;;
    *) echo "Error: unknown arg: $1" >&2; usage >&2; exit 1 ;;
  esac
done

# resolve --image all → expand
RESOLVED=()
if [[ ${#IMAGES[@]} -eq 0 ]]; then
  RESOLVED=("${ALL_IMAGES[@]}")
else
  for img in "${IMAGES[@]}"; do
    if [[ "$img" == "all" ]]; then
      RESOLVED=("${ALL_IMAGES[@]}")
    else
      RESOLVED+=("$img")
    fi
  done
fi
IMAGES=("${RESOLVED[@]}")

# validate image names
for img in "${IMAGES[@]}"; do
  case "$img" in
    cuda-llama-cpp|cuda-comfy|cuda-vllm) ;;
    *) echo "Error: unknown image '$img'. Valid: ${ALL_IMAGES[*]} (or 'all')" >&2; exit 1 ;;
  esac
done

case "$SYNC" in rsync|git) ;; *) echo "Error: --sync must be rsync or git" >&2; exit 1 ;; esac

# ---- locate repo root and load cluster.env ------------------------------
SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
REPO_ROOT=$(cd "$SCRIPT_DIR/../../../.." && pwd)
CLUSTER_ENV="$REPO_ROOT/spark/cluster/cluster.env"

if [[ ! -f "$CLUSTER_ENV" ]]; then
  echo "Error: $CLUSTER_ENV not found. Copy cluster.env.example and fill in." >&2
  exit 2
fi

# shellcheck disable=SC1090
. "$CLUSTER_ENV"

: "${SSH_USER:?cluster.env must set SSH_USER}"
: "${REPLICAS:?cluster.env must set REPLICAS}"
: "${LB_HOST:?cluster.env must set LB_HOST}"
: "${VLLM_PORT:=8000}"
: "${LB_PORT:=8080}"
# LB_STATS_PORT is vestigial: it belonged to the retired HAProxy stack. LiteLLM exposes no
# stats port, which is exactly why the old drain check (a curl to :8404) could never succeed.

# pick a default host (first non-LB replica)
if [[ -z "$HOST" ]]; then
  for r in $REPLICAS; do
    [[ "$r" != "$LB_HOST" ]] && { HOST="$r"; break; }
  done
fi
[[ -z "$HOST" ]] && { echo "Error: no non-LB replica in REPLICAS='$REPLICAS'" >&2; exit 1; }

if [[ "$HOST" == "$LB_HOST" && $FORCE -eq 0 ]]; then
  echo "Error: $HOST is LB_HOST — draining it takes the cluster API down." >&2
  echo "       Pass --force if you really mean it." >&2
  exit 1
fi

# Derive the LB SSH target. If --host has a domain suffix (FQDN) and LB_HOST
# from cluster.env is bare, apply the same suffix so SSH from off-cluster
# contexts (e.g. inside a primate container) can resolve the LB host too.
LB_TARGET="$LB_HOST"
if [[ -n "$LB_HOST_OVERRIDE" ]]; then
  LB_TARGET="$LB_HOST_OVERRIDE"
elif [[ "$HOST" == *.* && "$LB_HOST" != *.* ]]; then
  LB_TARGET="${LB_HOST}.${HOST#*.}"
fi

# ---- helpers ------------------------------------------------------------
log() { printf '\033[1;34m→\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!\033[0m %s\n' "$*" >&2; }

run() {
  # Print every command, execute only when not dry-run.
  printf '  $ %s\n' "$*"
  (( DRY_RUN )) && return 0
  eval "$@"
}

# Convenience SSH wrapper. Quote the remote command as a single arg.
sshx() {
  run "ssh -o BatchMode=yes ${SSH_USER}@${HOST} $(printf '%q' "$1")"
}

# Run a command on the LB host (not the target build host).
sshl() {
  run "ssh -o BatchMode=yes ${SSH_USER}@${LB_TARGET} $(printf '%q' "$1")"
}

# ---- safety: restore vLLM on exit if we drained it ----------------------
DRAINED=0
cleanup() {
  if (( DRAINED && ! NO_RESTART )); then
    warn "(cleanup) restoring vLLM on $HOST"
    ssh -o BatchMode=yes "${SSH_USER}@${HOST}" \
      'cd ~/spark-deploy/vllm && docker compose up -d' || \
      warn "(cleanup) restore failed — restart manually"
  fi
}
trap cleanup EXIT

# ---- plan --------------------------------------------------------------
log "Plan:"
echo "    host       : ${SSH_USER}@${HOST}"
echo "    images     : ${IMAGES[*]}"
echo "    sync       : ${SYNC}${GIT_REF:+ (ref=$GIT_REF)}"
echo "    drain vLLM : $((1-SKIP_DRAIN))"
echo "    restart    : $((1-NO_RESTART))"
echo "    LB host    : ${SSH_USER}@${LB_TARGET}"
echo "    dry-run    : ${DRY_RUN}"
echo

# ---- pre-flight on host -------------------------------------------------
# Checks what the build actually needs: a usable Docker daemon and a visible GPU. It used to
# also demand `sudo -n true`, which hard-failed the whole script the moment the cluster moved to
# the `gdeceiver` service account — that account is in `docker` and `users`, deliberately NOT in
# `sudo`. Nothing here needs root: `make <img>.build` is a docker build, and docker-group
# membership is exactly what buys you that without sudo.
log "Pre-flight on $HOST"
sshx 'set -e; docker version --format "{{.Server.Version}}" >/dev/null; nvidia-smi --query-gpu=name --format=csv,noheader | head -1'

# ---- capacity check -- BEFORE we stop anything ---------------------------
# This used to run AFTER the drain, and against HAProxy's stats CSV on :8404. Both were wrong:
# the LB is LiteLLM now (no stats port at all — the curl just fails), so the check counted zero
# UP replicas and exit 1'd *after* vLLM had already been stopped. Every normal run aborted.
#
# Ask the replicas themselves instead. Their vLLM /health is the ground truth, it does not
# depend on the LB, and it works whatever the LB happens to be.
PEERS=()
for r in $REPLICAS; do
  [[ "$r" != "$HOST" ]] && PEERS+=("$r")
done

# Is a replica serving? (0 = healthy). Quiet: callers decide what a failure means.
replica_healthy() {
  ssh -o BatchMode=yes -o ConnectTimeout=5 "${SSH_USER}@$1" \
    "curl -fsS --max-time 5 -o /dev/null http://127.0.0.1:${VLLM_PORT}/health" 2>/dev/null
}

if (( ! SKIP_DRAIN && ! DRY_RUN )); then
  if (( ${#PEERS[@]} == 0 )); then
    # Single-replica cluster: "drain" is not a drain, it is an outage. Say so plainly and make
    # the operator opt in, rather than pretending the cluster is still served.
    if (( ! ALLOW_OUTAGE )); then
      warn "$HOST is the ONLY replica in REPLICAS='$REPLICAS'."
      warn "Stopping vLLM on it takes the served model OFFLINE for the whole build — there is"
      warn "nothing to fail over to. This is an outage, not a drain."
      warn "Re-run with --allow-outage to accept that, or --skip-drain to build without stopping"
      warn "vLLM (slower, and the build competes with the server for unified memory)."
      exit 1
    fi
    warn "Single-replica cluster — the served model will be OFFLINE for this build (--allow-outage)."
  else
    log "Checking peer capacity before draining $HOST (need >=1 healthy peer)"
    healthy=()
    for p in "${PEERS[@]}"; do
      if replica_healthy "$p"; then healthy+=("$p"); echo "    $p  serving"
      else                          echo "    $p  NOT serving"; fi
    done
    if (( ${#healthy[@]} == 0 )); then
      warn "No peer replica is serving — draining $HOST would leave zero serving capacity."
      warn "Wait for a peer to recover, or pass --allow-outage / --skip-drain deliberately."
      exit 1   # nothing has been stopped yet: the cluster is exactly as we found it
    fi
    log "Peers still serving: ${healthy[*]}"
  fi
fi

# ---- drain --------------------------------------------------------------
if (( ! SKIP_DRAIN )); then
  log "Draining $HOST (docker compose stop vllm — frees the unified memory the build needs)"
  sshx 'cd ~/spark-deploy/vllm && docker compose stop'
  DRAINED=1

  if (( ! DRY_RUN )); then
    # Confirm it is actually down. LiteLLM has no per-backend stats to observe (that was the
    # old :8404 poll), so verify at the source: the replica's own vLLM must stop answering.
    log "Confirming vLLM stopped on $HOST"
    for _ in $(seq 1 12); do
      replica_healthy "$HOST" || break
      sleep 5
    done
    if replica_healthy "$HOST"; then
      warn "vLLM on $HOST is STILL serving after 60s — it did not stop. Aborting before the build"
      warn "competes with it for unified memory. (The EXIT trap will restore the stack.)"
      exit 1
    fi
    log "vLLM on $HOST is down"

    # The endpoint should still be alive for everyone else (unless we knowingly took it down).
    if (( ${#PEERS[@]} > 0 )); then
      if ssh -o BatchMode=yes -o ConnectTimeout=5 "${SSH_USER}@${LB_TARGET}" \
           "curl -fsS --max-time 5 -o /dev/null http://127.0.0.1:${LB_PORT}/health/liveliness" 2>/dev/null; then
        log "LB on $LB_TARGET:$LB_PORT still live"
      else
        warn "LB on $LB_TARGET:$LB_PORT is not answering /health/liveliness — the cluster endpoint"
        warn "may be down independently of this build. Continuing; check the LB."
      fi
    fi
  fi
fi

# ---- sync code to host --------------------------------------------------
log "Sync code to $HOST via $SYNC"
case "$SYNC" in
  rsync)
    # Ensure parent dir exists; rsync only creates the final path component.
    sshx 'mkdir -p ~/workspace'
    run "rsync -avz --delete --exclude='.git' --exclude='vault.tar.gz' --exclude='*-home' '$REPO_ROOT/' '${SSH_USER}@${HOST}:~/workspace/code-monkeys/'"
    ;;
  git)
    REF="${GIT_REF:-$(git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD)}"
    REMOTE_URL=$(git -C "$REPO_ROOT" remote get-url origin)
    sshx "[ -d ~/workspace/code-monkeys/.git ] || (mkdir -p ~/workspace && git clone $REMOTE_URL ~/workspace/code-monkeys)"
    sshx "cd ~/workspace/code-monkeys && git fetch --all --prune && git checkout '$REF' && git pull --ff-only"
    ;;
esac

# ---- build --------------------------------------------------------------
for img in "${IMAGES[@]}"; do
  log "Building $img on $HOST"
  sshx "cd ~/workspace/code-monkeys/primates && make ${img}.build"
done

# ---- restart ------------------------------------------------------------
if (( ! NO_RESTART )); then
  log "Restarting vLLM on $HOST (docker compose up -d)"
  sshx 'cd ~/spark-deploy/vllm && docker compose up -d'
  DRAINED=0  # cleanup trap no-op now

  # Wait for it to actually come back rather than just claiming it will. The weights mmap-load
  # cold in ~2 min, and LiteLLM has no backend-state view to watch, so poll the replica itself.
  if (( ! DRY_RUN )); then
    log "Waiting up to 5 min for vLLM on $HOST to serve again (cold weight load)"
    back=0
    for _ in $(seq 1 30); do
      if replica_healthy "$HOST"; then back=1; break; fi
      sleep 10
    done
    if (( back )); then
      log "vLLM on $HOST is serving again"
    else
      warn "vLLM on $HOST is not serving after 5 min. Check it:"
      warn "  ssh ${SSH_USER}@${HOST} 'cd ~/spark-deploy/vllm && docker compose logs --tail=50'"
    fi
  else
    log "Watch: ssh ${SSH_USER}@${HOST} 'curl -sS http://127.0.0.1:${VLLM_PORT}/health'"
  fi
fi

log "Done."
