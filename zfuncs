# load env file into current shell as exported variables
function setenv() {
  local __ENV_FILE="${1:-$(dirname $(readlink -f ${(%):-%x}))/env}"
  if [[ ! -f "$__ENV_FILE" ]]; then
    echo "env file not found: ${__ENV_FILE}"
    return 1
  fi
  set -a
  source "$__ENV_FILE"
  set +a
  echo "loaded: ${__ENV_FILE}"
}

# starts a primate container with a persistent home volume
function primate() {

  local __NO_WORKSPACE=false
  local __args=()
  for arg in "$@"; do
    if [[ "$arg" == "--no-workspace" ]]; then
      __NO_WORKSPACE=true
    else
      __args+=("$arg")
    fi
  done
  set -- "${__args[@]}"

  if [[ "$#" -lt 1 ]]; then
    echo "Usage: primate <image> [--no-workspace] [docker args...]"
    return 1
  fi

  local __IMAGE=$1
  shift

  local __WORKSPACE_MOUNT=()
  if [[ "$__NO_WORKSPACE" == false ]]; then
    __WORKSPACE_MOUNT=(--volume "$(pwd):/home/codemonkey/workspace")
  fi

  local __ENV_FILE="$(dirname $(readlink -f ${(%):-%x}))/env"
  local __ENV_FILE_MOUNT=()
  if [[ -f "$__ENV_FILE" ]]; then
    __ENV_FILE_MOUNT=(--env-file "$__ENV_FILE")
  fi

  echo "starting ${__IMAGE} with volume ${__IMAGE}-home"

  local __CMD=(zsh)
  local __ENTRYPOINT=$(docker inspect --format='{{len .Config.Entrypoint}}' "${__IMAGE}:latest" 2>/dev/null)
  if [[ "$__ENTRYPOINT" -gt 0 ]]; then
    __CMD=()
  fi

  local __GPU_OPTS=()
  if [[ "$(uname -r)" == *-nvidia ]]; then
    __GPU_OPTS=(--gpus all)
  fi

  local __PORT_OPTS=()
  local __PORTS=$(docker inspect --format='{{range $p, $_ := .Config.ExposedPorts}}{{$p}} {{end}}' "${__IMAGE}:latest" 2>/dev/null)
  for __PORT in ${=__PORTS}; do
    __PORT_OPTS+=(-p "${__PORT%/*}:${__PORT%/*}")
  done

  local __SSH_MOUNT=""
  if [[ -d ~/.ssh ]]; then
    __SSH_MOUNT="$(cd -P ~/.ssh && pwd)"
  fi

  local __AWS_MOUNT=""
  if [[ -d ~/.aws ]]; then
    __AWS_MOUNT="$(cd -P ~/.aws && pwd)"
  fi

  docker run --rm -it \
    --hostname "${__IMAGE}" \
    "${__ENV_FILE_MOUNT[@]}" \
    "${__GPU_OPTS[@]}" \
    "${__PORT_OPTS[@]}" \
    ${__SSH_MOUNT:+--volume "${__SSH_MOUNT}:/home/codemonkey/.ssh"} \
    ${__AWS_MOUNT:+--volume "${__AWS_MOUNT}:/home/codemonkey/.aws"} \
    "${__WORKSPACE_MOUNT[@]}" \
    --volume ${__IMAGE}-home:/home/codemonkey \
    --user=codemonkey:codemonkey \
    $@ \
    ${__IMAGE} "${__CMD[@]}"
}

function _primate() {
  local known_primates=(codemonkey minion embedded miniforge3 claude opencode llama-cpp-spark comfy-ui-spark lamp huggingface)
  local local_images=(${(f)"$(docker images --format '{{.Repository}}' 2>/dev/null)"})
  local available=()
  for name in "${known_primates[@]}"; do
    if (( ${local_images[(Ie)$name]} )); then
      available+=("$name")
    fi
  done

  case "$CURRENT" in
    2) _describe 'primate image' available ;;
    *) _values 'options' '--no-workspace[Do not mount the current directory as workspace]' ;;
  esac
}
compdef _primate primate

function primate-upgrade() {
  if [[ "$#" -lt 1 ]]; then
    echo "Usage: primate-upgrade <image> [image...]"
    echo "       primate-upgrade --all"
    return 1
  fi

  local __REPO="$(dirname $(readlink -f ${(%):-%x}))"
  local __IMAGES=("$@")

  if [[ "$1" == "--all" ]]; then
    __IMAGES=()
    local known=(codemonkey minion embedded miniforge3 claude opencode lamp huggingface)
    for name in "${known[@]}"; do
      if docker volume inspect "${name}-home" &>/dev/null; then
        __IMAGES+=("$name")
      fi
    done
    if [[ ${#__IMAGES[@]} -eq 0 ]]; then
      echo "No primate home volumes found."
      return 0
    fi
  fi

  for __IMAGE in "${__IMAGES[@]}"; do
    local __VOL="${__IMAGE}-home"
    if ! docker volume inspect "$__VOL" &>/dev/null; then
      echo "skip: volume ${__VOL} does not exist"
      continue
    fi

    echo "upgrading ${__IMAGE}..."
    docker run --rm \
      --volume "${__REPO}:/opt/user-jhunt:ro" \
      --volume "${__VOL}:/home/codemonkey" \
      codemonkey:latest bash -c '
        SRC=/opt/user-jhunt
        HOME=/home/codemonkey

        # dotfiles
        cp "$SRC/zaliases"  "$HOME/.zaliases"
        cp "$SRC/zbase"     "$HOME/.zbase"
        cp "$SRC/zprofile"  "$HOME/.zprofile"
        cp "$SRC/gitconfig" "$HOME/.gitconfig"
        cp "$SRC/gitignore" "$HOME/.gitignore"
        cp "$SRC/vimrc"     "$HOME/.vimrc"
        cp "$SRC/toprc"     "$HOME/.toprc"
        cp "$SRC/zshrc.template" "$HOME/.zshrc"
        cp "$SRC/zfuncs"    "$HOME/.zfuncs"

        # oh-my-zsh update
        if [ -d "$HOME/.oh-my-zsh" ]; then
          git -C "$HOME/.oh-my-zsh" pull --quiet 2>/dev/null || true
          for plugin in zsh-autosuggestions zsh-completions zsh-syntax-highlighting; do
            if [ -d "$HOME/.oh-my-zsh/custom/plugins/$plugin" ]; then
              git -C "$HOME/.oh-my-zsh/custom/plugins/$plugin" pull --quiet 2>/dev/null || true
            fi
          done
        fi

        # oh-my-zsh theme
        mkdir -p "$HOME/.oh-my-zsh/custom/themes"
        cp "$SRC/jjh.zsh-theme" "$HOME/.oh-my-zsh/custom/themes/jjh.zsh-theme"

        # claude config
        if [ -d "$SRC/claude" ]; then
          mkdir -p "$HOME/.claude/commands"
          cp "$SRC/claude/settings.json" "$HOME/.claude/settings.json"
          cp "$SRC/claude/commands/"* "$HOME/.claude/commands/" 2>/dev/null
        fi

        # fix ownership
        chown -R codemonkey:codemonkey "$HOME"
      '
    echo "  done: ${__IMAGE}"
  done
}

# Take A Dump (takes a java heapdump in a running container)
function tad() {

  if [[ "$#" -ne 1 ]]; then
    echo "Usage: take-a-dump <target container name>"
    return 1
  fi
  local _TARGET=$1

  echo "Taking a dump of ${_TARGET}"

  _PID=$(docker exec ${_TARGET} ps aux | grep java | awk '{print $2}')
  if [[ -z ${_PID} ]]; then
	  echo "unable to to find Java process"
	  return 1
  fi
  echo "Found Java PID: ${_PID}"

  _JDK=$(docker exec ${_TARGET} ps aux | grep java | awk '{print $11}' | sed 's/\(.*\)\/java/\1/g' )
  if [[ -z ${_JDK} ]]; then
	  echo "unable to find jmap"
	  return 1
  fi
  echo "Found Java PID: ${_JDK}"

  _DATE=$(date +"%s")
  _FILENAME="${_TARGET}--heap-${_DATE}.hprof"
  echo "Taking a heap dump of ${TARGET} with PID:${_PID} using ${_JDK}/jmap -dump:format=b,file=/dumps/${TARGET}-heap-${_DATE}.hprof ${_PID}"
  docker exec ${_TARGET} $_JDK/jmap -dump:format=b,file=/dumps/${_TARGET}-heap-01.hprof $_PID

  echo "dump taken ${_FILENAME}, check in host /tmp directory"
}

function which-os() {
  local os=$(uname -a | awk '{print $1}')
  if [[ "${os}" = "Darwin" ]]; then
    echo -n "MacOS"
  elif [[ "${os}" = "Linux" ]]; then
    echo -n "Linux"
  elif [[ "${os}" = "Win32" ]]; then
    echo -n "WSL"
  else 
    return "Unknown"
  fi
}

function code-mac() {
  open -a XQuartz
  xhost +localhost

  if [[ $# = 0 ]]
  then
    open -a "Visual Studio Code"
  else
    [[ $1 = /* ]] && F="$1" || F="$PWD/${1#./}"
    open -a "Visual Studio Code" --args "$F"
  fi
}

function code-linux() {
  if [[ $# = 0 ]]
  then
    code .
  else
    code $@
  fi 
}

