function code-here () {
  local os=$(which-os)
  if [[ "${os}" = "Linux" ]]; then
    code-linux $@
    return
  elif [[ "${os}" = "MacOS" ]]; then
    code-mac $@
    return
  fi
}

function tree () {
  local os=$(which-os)
  if [[ "${os}" != "MacOS" ]]; then
    /usr/bin/tree $@
    return
  fi
  if [[ -n $* ]]; then
    if [[ $1 == /* ]]; then
      _TARGET=$1
    else
      _TARGET=$(pwd)/$1
    fi
    docker run --rm -e _TARGET=${_TARGET} -v ${_TARGET}:/tmp minion bash -c 'echo ${_TARGET}; cd /tmp; tree | tail -n +2 '
  else
    local _TARGET=$(pwd)
    docker run --rm -e _TARGET=${_TARGET} -v $(pwd):/tmp minion bash -c 'echo ${_TARGET}; cd /tmp; tree | tail -n +2 '
  fi
}

function TAR () {
  if [[ "$#" -ne 3 ]]; then
    echo "Usage: TAR <args> <target> <source>"
    return 1
  fi

  local _ARGS=$1
  local _TARGET=$2
  local _SOURCE=$3
  local _DEST=$(pwd)

  docker run --rm \
    -e _ARGS=${_ARGS} \
    -e _TARGET=${_TARGET} \
    -e _SOURCE=${_SOURCE} \
    -v ${_DEST}:/tmp/.TAR.ouput \
    -v ${_DEST}/${_SOURCE}:/tmp/${_SOURCE} \
    minion bash -c 'cd /tmp; tar ${_ARGS} ${_TARGET} ${_SOURCE}; mv ${_TARGET} /tmp/.TAR.ouput;'
}

function clamscan() {
  local _TARGET=
  if [[ -n $* ]]; then
    _TARGET=$1
  else
    _TARGET=$(pwd)
  fi
  docker run --rm -v ${_TARGET}:/scan minion bash -c 'clamscan -r /scan' | sed 's/\/scan\///'
}

function pmd () {
  #pmd check -d /usr/src -R rulesets/java/quickstart.xml -f text
  local _TARGET=
  if [[ -n $* ]]; then
    _TARGET=$[$#]
  else
    _TARGET=$(pwd)
  fi
    docker run --rm -e _TARGET=${_TARGET} -v $(pwd):/tmp/src minion bash -c 'echo ${_TARGET}; cd /tmp; pmd check -d /tmp/src rulesets/java/quickstart.xml -f text'
}

function watch() {
  if [[ "$#" -ne 1 ]]; then
    echo "Usage: watch <command>"
    return 1
  fi
  local _TARGET=$1
  local _STARTED=$(date)

  while (true); do
    clear
    local _LAST=$(date)

    echo "watching ${_TARGET}"
    echo "started on ${_STARTED}, last run on ${_LAST}, rerun in 2 seconds"

    echo
    zsh -c "${_TARGET}"
    sleep 2
  done
}

